--- !u!114 &4650920426462258007
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 3672945474974383695}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 3dd2cea79599d400da99f5ec437400ca, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueConfig
  dialogueLines:
  - npcText: "Elvis: You\u2019ve been quiet. Been avoiding everyone?"
    options: []
  - npcText: "Tom: Yeah\u2026 just working, trying to get by."
    options: []
  - npcText: 'Elvis: You look exhuasted.'
    options: []
  - npcText: "Tom: It's Jackson\u2026 he\u2019s gone."
    options: []
  - npcText: "Elvis: I know brother. I\u2019m sorry."
    options: []
  - npcText: 'Tom: He left me a last wish.'
    options: []
  - npcText: 'Elvis: ...What is it?'
    options: []
  - npcText: 'Tom: A flower. A real flower. He wanted me to get one and give it to
      a women named Chelsea.'
    options: []
  - npcText: 'Elvis: A flower? How are you supposed to get that? And who''s Chelsea???'
    options: []
  - npcText: "Tom: I don\u2019t know neither. But I have to try, I owed him a lot,
      you know it."
    options: []
  - npcText: 'Elvis: Wait... I might know a place. There''s a black market in the
      hood, they sell everything.'
    options: []
  - npcText: 'Tom: Black market... Where is it? You''ve been there?'
    options: []
  - npcText: 'Elvis: No. I just heard of it in the bar. But I am sure it exists.'
    options: []
  - npcText: 'Tom: Then I''ll go for it. '
    options: []
