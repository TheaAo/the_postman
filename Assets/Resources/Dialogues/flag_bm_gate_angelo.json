      "nextId": "angelo_ramen_push",
      "options": [],
      "events": []
    },
    "angelo_ramen_push": {
      "id": "angelo_ramen_push",
      "speaker": "Tom",
      "text": "The ramen is really important for Knife and Knife wants it now. Let me in or I told Brien who told me to leave.",
