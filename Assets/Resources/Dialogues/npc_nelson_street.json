{
  "id": "npc_nelson_street",
  "startNodeId": "nelson_01",
  "nodes": {
    "nelson_01": {
      "id": "nelson_01",
      "speaker": "Tom",
      "text": "How's going Nelson, you're on street duty today huh.",
      "nextId": "nelson_02",
      "options": [],
      "events": []
    },
    "nelson_02": {
      "id": "nelson_02",
      "speaker": "Nelson",
      "text": "Yeah nothing interesting. You?",
      "nextId": "nelson_03",
      "options": [],
      "events": []
    },
    "nelson_03": {
      "id": "nelson_03",
      "speaker": "Tom",
      "text": "Just hanging around.",
      "nextId": "nelson_04",
      "options": [],
      "events": []
    },
    "nelson_04": {
      "id": "nelson_04",
      "speaker": "Nelson",
      "text": "You aren't gonna talk to me when you are 'just hanging around'. Don't waste my time.",
      "nextId": "nelson_05",
      "options": [],
      "events": []
    },
    "nelson_05": {
      "id": "nelson_05",
      "speaker": "Tom",
      "text": "Well... I wanna get something that could not be found in a casual grocery. Any thought?",
      "nextId": "nelson_06",
      "options": [],
      "events": []
    },
    "nelson_06": {
      "id": "nelson_06",
      "speaker": "Nelson",
      "text": "Maybe I have and maybe I don't.",
      "options": [
        {
          "text": "Give him 500 euros",
          "nextId": "nelson_bribe",
          "requireFlags": [],
          "setFlags": ["has_nelson_reco", "bribed_nelson"],
          "cost": 500,
          "insufficientText": "This is a lot...",
          "insufficientNextId": "nelson_insufficient_options"
        },
        {
          "text": "Nelson, come on—don't be like that.",
          "nextId": "nelson_refuse",
          "setFlags": ["Route.GoRamen"]
        }
      ],
      "events": []
    },
    "nelson_bribe": {
      "id": "nelson_bribe",
      "speaker": "Nelson",
      "text": "You do know the rules. Go to \"TBD\" and say Rabbit recommends you.",
      "nextId": null,
      "options": [],
      "events": ["has_nelson_reco", "Route.GoGuard"]
    },
    "nelson_refuse": {
      "id": "nelson_refuse",
      "speaker": "Nelson",
      "text": "And you know I am a police. Get off my face before I arrest you for assaulting a police.",
      "nextId": null,
      "options": [],
      "events": ["Route.GoRamen"]
    },
    "nelson_insufficient_options": {
      "id": "nelson_insufficient_options",
      "speaker": "Tom",
      "text": "(Well then...)",
      "options": [
        {
          "text": "Screw you!",
          "nextId": null,
          "setFlags": ["Route.GoPolice"]
        },
        {
          "text": "I shall go get some cash.",
          "nextId": null,
          "setFlags": ["nelson_need_cash"]
        }
      ],
      "events": []
    }
  }
}
