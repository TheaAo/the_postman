  dialogueLines:
  - npcText: "The Boss: \u2026You said you wanted the flower?"
    options: []
  - npcText: " Tom: Yes. I\u2019ll pay whatever it costs."
    options: []
  - npcText: "The Boss: Ah\u2026 Young man. Always thinking you can get whatever
      you want."
    options: []
  - npcText: 'Tom: ...

'
    options: []
  - npcText: " The Boss: \u2026Everyone has their wishes. So do I\u2026"
    options: []
  - npcText: 'Tom: Then what do you want?'
    options: []
  - npcText: "The Boss: \u2026Me? I want an answer. Can you give me that?"
    options: []
  - npcText: "Tom: \u2026I don\u2019t know. But I can try."
    options: []
  - npcText: 'The Boss: It''s also about the flower. So, what flower grows on your
      face?'
    options: []
  - npcText: 'Tom: ...'
    options: []
  - npcText: 'Tom: I guess...

'
    options:
    - buttonText: Tulips
      onClick:
        m_PersistentCalls:
          m_Calls:
          - m_Target: {fileID: 771922636}
            m_TargetAssemblyTypeName: OptionManager, Assembly-CSharp
