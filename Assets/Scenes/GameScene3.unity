  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueConfig
  dialogueLines:
  - npcText: 'Angelo: Hold on there. You are not allow to get in here. '
    options: []
  - npcText: 'Tom: Rabbit told me to be here.'
    options: []
  - npcText: 'Angelo: And my dog told me to buy some steaks for dinner. Now get off.'
    options: []
  - npcText: 'Tom: What? It''s Nelson. You must know him, he said I can go in, please.'
    options: []
  - npcText: 'Angelo: Which Nelson? Been dizzy these days, might need something to
      refresh. '
    options:
    - buttonText: 'Option 1: gives him the last 100 euros you have in his pocket'
      onClick:
        m_PersistentCalls:
          m_Calls:
          - m_Target: {fileID: 1299974578}
            m_TargetAssemblyTypeName: OptionManager, Assembly-CSharp
            m_MethodName: AngeloOption1
