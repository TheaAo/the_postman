              m_IntArgument: 0
              m_FloatArgument: 0
              m_StringArgument: 
              m_BoolArgument: 0
            m_CallState: 2
    - buttonText: 'Option 2: You need the last money to buy that flower. Leave.'
      onClick:
        m_PersistentCalls:
